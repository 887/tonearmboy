<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Audio library access. READ_MEDIA_AUDIO is the Android 13+ replacement
         for READ_EXTERNAL_STORAGE. Keep the legacy permission for API 32 and
         below so older devices can still scan MediaStore. -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Foreground media playback service (Media3 MediaSessionService). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- D.9d.2: low-priority foreground service that watches MediaStore +
         configured SAF trees for changes and triggers a debounced rescan
         via WorkManager. Android 14+ requires a foreground-service type
         to be declared at install time and at runtime; `dataSync` is the
         documented category for "user-initiated background data sync /
         scan / index work". -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Notification posting (Android 13+) for the playback notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep the CPU awake during active playback. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/Theme.Tonearm">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Media3 foreground media-playback service. The intent filter is
             the canonical contract a MediaSessionService advertises so that
             system controllers (and our in-app MediaController) can find it. -->
        <service
            android:name=".playback.PlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- Phase E.5: Media3's MediaButtonReceiver is required for the
             playback-resumption flow (Bluetooth + Android System UI restart).
             Without it, MediaSession.Callback.onPlaybackResumption is never
             invoked. The receiver itself ships in the media3-session AAR. -->
        <receiver android:name="androidx.media3.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- Smoke-test entry point: receives an ACTION_PLAY broadcast with a
             `path` extra, hands the URI to the running service via
             MediaController, and logs ExoPlayer state transitions to logcat
             so the scripted smoke test can assert STATE_READY without a UI. -->
        <receiver
            android:name=".playback.SmokeTestReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.eight87.tonearm.action.SMOKE_PLAY" />
            </intent-filter>
        </receiver>

        <!-- Phase C smoke-test entry point: runs a MediaStore scan and logs
             the result counts under the tonearm tag so the library smoke
             test can assert the seeded fixtures were picked up. -->
        <receiver
            android:name=".data.LibraryScanReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.eight87.tonearm.action.LIBRARY_SCAN" />
            </intent-filter>
        </receiver>

        <!-- D.9d.2: low-priority foreground service that observes
             MediaStore + every persisted SAF tree URI and enqueues a
             debounced LibraryRescanWorker on change. Started + stopped
             by the "Automatic reloading" toggle in Settings > Content. -->
        <service
            android:name=".data.watcher.LibraryWatcherService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- D.9d.2: tap-to-disable receiver for the watcher's sticky
             notification. Stops the service AND flips the persisted
             "Automatic reloading" setting back to off. -->
        <receiver
            android:name=".data.watcher.LibraryWatcherDisableReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.eight87.tonearm.action.WATCHER_DISABLE" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
