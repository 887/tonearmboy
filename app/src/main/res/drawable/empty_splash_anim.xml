<?xml version="1.0" encoding="utf-8"?>
<!--
  Empty AnimatedVectorDrawable used as `windowSplashScreenAnimatedIcon`
  to suppress the system splash icon entirely. The Android 12+
  SplashScreen API hard-clips the icon to a circle and there is no
  attribute to disable that mask. The workaround: hand it a drawable
  that paints nothing. The system still allocates the circle area but
  it stays invisible against the matching `windowSplashScreenBackground`,
  so the cold-start frame is a flat colour with no circle. The
  activity's first composable frame then paints the full square
  artwork via `SplashOverlay` in MainActivity.

  Stock Pixel renders this cleanly; some OEM skins (Xiaomi notably)
  draw a black circular mask under the empty icon — accept that as
  best-effort and document.
-->
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android">
    <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">
            <path
                android:fillColor="#00000000"
                android:pathData="M0,0 L0,0 Z" />
        </vector>
    </aapt:attr>
</animated-vector>
