<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tonearmboy launch theme. The Android 12+ SplashScreen API
        hard-clips `windowSplashScreenAnimatedIcon` to a circle and
        there is no system attribute to disable that. Earlier
        attempts (full-canvas foreground / layer-list windowBackground
        / 70 % then 60 % shrunk icon) all kept the circular shape on
        screen.

        Working approach (researched May 2026): point
        `windowSplashScreenAnimatedIcon` at an empty
        AnimatedVectorDrawable so the system's circle slot paints
        nothing тАФ the cold-start frame is just the solid
        `windowSplashScreenBackground` colour, no visible circle on
        stock Pixel. `MainActivity` then renders a `SplashOverlay`
        composable showing the full square launcher artwork for
        ~700 ms before fading into the main UI. Two-stage splash:
        the system frame is empty, the Compose frame is square.

        Caveat: some OEM skins (notably Xiaomi) draw a black circle
        mask under the empty icon тАФ best-effort.
    -->
    <style name="Theme.Tonearmboy" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/empty_splash_anim</item>
        <item name="windowSplashScreenAnimationDuration">50</item>
        <item name="postSplashScreenTheme">@style/Theme.Tonearmboy.Main</item>
    </style>

    <style name="Theme.Tonearmboy.Main" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/launcher_background</item>
    </style>

</resources>
