<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tonearmboy launch theme. Originally (D.17.2) used the
        SplashScreen API's `windowSplashScreenAnimatedIcon` path for
        the cold-boot icon, but that path force-clips the icon to a
        circle on Android 12+, hiding everything outside the inscribed
        circle of the square launcher artwork (fox + vinyl + tonearm).
        The user wanted the full square visible.

        We keep the `Theme.SplashScreen` parent (mandatory for the
        SplashScreen 1.x compat library to wire `installSplashScreen`
        properly on older APIs), drop the `windowSplashScreenAnimatedIcon`
        + `windowSplashScreenIconBackgroundColor` so the system stops
        drawing the circle-clipped icon, and set `android:windowBackground`
        to a layer-list that paints the full launcher foreground
        centred. The splash background colour stays for continuity
        with the launcher icon backdrop.
    -->
    <style name="Theme.Tonearmboy" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/launcher_background</item>
        <item name="android:windowBackground">@drawable/splash_window_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Tonearmboy.Main</item>
    </style>

    <style name="Theme.Tonearmboy.Main" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/launcher_background</item>
    </style>

</resources>
