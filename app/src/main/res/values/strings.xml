<?xml version="1.0" encoding="utf-8"?>
<!--
  T.A.1 — naming scheme.

  Format: `<surface>_<role>` lowercase snake.
  Surfaces:
    library_     — library tabs / detail screens / sort sheet / multi-select bar / custom tabs
    playing_     — NowPlaying / MiniPlayer / queue
    settings_    — settings root + sub-pages + dialogs
    playlist_    — playlist crud / picker / collision dialog
    search_      — search overlay
    permission_  — runtime permission rationale + first-launch surfaces
    dialog_      — generic dialog buttons (OK / Cancel) when no surface fits
    error_       — error / failure messages (snackbars, toasts)
    cd_          — content-descriptions for icons + non-text controls

  testTags, log tags, internal sentinels, and code constants stay
  hard-coded — they are not user-facing.
-->
<resources xmlns:tools="http://schemas.android.com/tools" tools:locale="en">

  <!-- App identity (Phase E.1). -->
  <string name="app_name">tonearmboy</string>
  <string name="playback_notification_channel_name">Playback</string>

  <!-- T.A.3 — library tab names (rail + custom-tab content type labels). -->
  <string name="library_tab_songs">Songs</string>
  <string name="library_tab_albums">Albums</string>
  <string name="library_tab_artists">Artists</string>
  <string name="library_tab_genres">Genres</string>
  <string name="library_tab_playlists">Playlists</string>

  <!-- T.A.3 — empty-state messages, one per library tab. -->
  <string name="library_empty_songs">No tracks yet.</string>
  <string name="library_empty_albums">No albums yet. Add audio files to your device, then tap Rescan music.</string>
  <string name="library_empty_artists">No artists yet.</string>
  <string name="library_empty_genres">No genres yet.</string>
  <string name="library_empty_playlists">No playlists yet. Tap + to create one.</string>

  <!-- T.A.2 — settings root section + group labels. -->
  <string name="settings_section_settings">Settings</string>
  <string name="settings_section_look_and_feel">Look and Feel</string>
  <string name="settings_section_personalize">Personalize</string>
  <string name="settings_section_content">Content</string>
  <string name="settings_section_audio">Audio</string>
  <string name="settings_group_appearance">Appearance</string>
  <string name="settings_group_behaviour">Behaviour</string>
  <string name="settings_group_library">Library</string>
  <string name="settings_group_about">About</string>
  <string name="settings_group_theme">Theme</string>
  <string name="settings_group_display">Display</string>
  <string name="settings_group_music">Music</string>
  <string name="settings_group_images">Images</string>
  <string name="settings_group_playback">Playback</string>
  <string name="settings_group_volume_normalization">Volume normalization</string>
  <string name="settings_group_album_art_sources">Album art sources</string>

</resources>
